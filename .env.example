# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=harbor
DB_PASSWORD=harbor_dev
DB_NAME=harbor

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=harbor_minio
MINIO_SECRET_KEY=harbor_minio_dev
MINIO_BUCKET=harbor-documents
MINIO_SECURE=false

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxx
AI_ENABLED=true
AI_MODEL=claude-sonnet-4-20250514

# Email (IMAP/SMTP)
EMAIL_ENABLED=false
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=broker@brokerage.com
IMAP_PASSWORD=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=broker@brokerage.com
SMTP_PASSWORD=

# OCR
OCR_ENGINE=paddleocr
TESSERACT_LANG=chi_sim+eng

# App
APP_NAME=Harbor
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000

# Optional: Alibaba Cloud OSS (instead of MinIO)
# OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_BUCKET=harbor-documents
